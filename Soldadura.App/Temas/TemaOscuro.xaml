<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── Fondos ───────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="PincelFondoVentana"   Color="#1A202C"/>
    <SolidColorBrush x:Key="PincelFondoPanel"     Color="#2D3748"/>
    <SolidColorBrush x:Key="PincelFondoControl"   Color="#2D3748"/>
    <SolidColorBrush x:Key="PincelFondoLectura"   Color="#1A202C"/>
    <SolidColorBrush x:Key="PincelFondoCabecera"  Color="#2D3748"/>
    <SolidColorBrush x:Key="PincelFondoAlt"       Color="#252D3D"/>
    <SolidColorBrush x:Key="PincelFondoResultado" Color="#1A202C"/>

    <!-- ── Texto ────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="PincelTextoPrimario"    Color="#E2E8F0"/>
    <SolidColorBrush x:Key="PincelTextoSecundario"  Color="#A0AEC0"/>
    <SolidColorBrush x:Key="PincelTextoDesactivado" Color="#4A5568"/>
    <SolidColorBrush x:Key="PincelTextoLectura"     Color="#CBD5E0"/>
    <SolidColorBrush x:Key="PincelTextoEstado"      Color="#68D391"/>

    <!-- ── Acento y bordes ──────────────────────────────────────────── -->
    <SolidColorBrush x:Key="PincelPrimario"    Color="#63B3ED"/>
    <SolidColorBrush x:Key="PincelBorde"       Color="#4A5568"/>
    <SolidColorBrush x:Key="PincelBordeFoco"   Color="#63B3ED"/>
    <SolidColorBrush x:Key="PincelBordeError"  Color="#FC8181"/>
    <SolidColorBrush x:Key="PincelSeparador"   Color="#4A5568"/>

    <!-- ── Botones ──────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="PincelFondoBoton"  Color="#2D3748"/>
    <SolidColorBrush x:Key="PincelHoverBoton"  Color="#4A5568"/>
    <SolidColorBrush x:Key="PincelPresBoton"   Color="#718096"/>

    <!-- ── Diagrama de ejes ─────────────────────────────────────────── -->
    <SolidColorBrush x:Key="PincelFondoDiagrama"    Color="#1A202C"/>
    <SolidColorBrush x:Key="PincelPiezaDiagrama"    Color="#2D3748"/>
    <SolidColorBrush x:Key="PincelTextoDiagrama"    Color="#E2E8F0"/>

</ResourceDictionary>
