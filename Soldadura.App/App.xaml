<Application x:Class="Soldadura.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Tema inicial: TemaClaro. ThemeManager lo intercambia en runtime. -->
                <ResourceDictionary Source="Temas/TemaClaro.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Convertidor global -->
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>

            <!-- ── Button (implícito) ──────────────────────────────────────── -->
            <Style TargetType="Button">
                <Setter Property="Padding"         Value="10,4"/>
                <Setter Property="MinWidth"        Value="54"/>
                <Setter Property="Background"      Value="{DynamicResource PincelFondoBoton}"/>
                <Setter Property="BorderBrush"     Value="{DynamicResource PincelBorde}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Foreground"      Value="{DynamicResource PincelTextoPrimario}"/>
                <Setter Property="Cursor"          Value="Hand"/>
                <Setter Property="FontSize"        Value="12"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{DynamicResource PincelHoverBoton}"/>
                    </Trigger>
                    <Trigger Property="IsPressed" Value="True">
                        <Setter Property="Background" Value="{DynamicResource PincelPresBoton}"/>
                    </Trigger>
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter Property="Opacity" Value="0.45"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- ── GroupBox (implícito) ───────────────────────────────────── -->
            <!-- Template propio: el template por defecto de WPF dibuja el borde con un color
                 fijo e ignora BorderBrush, por eso no cambiaba en modo oscuro. Aquí el borde
                 usa TemplateBinding BorderBrush → sigue el tema. -->
            <Style TargetType="GroupBox">
                <Setter Property="BorderBrush"     Value="{DynamicResource PincelBorde}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding"         Value="8,4,8,8"/>
                <Setter Property="Margin"          Value="0,0,0,6"/>
                <Setter Property="Foreground"      Value="{DynamicResource PincelPrimario}"/>
                <Setter Property="FontWeight"      Value="SemiBold"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="GroupBox">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <ContentPresenter Grid.Row="0" ContentSource="Header"
                                                  RecognizesAccessKey="True"
                                                  TextElement.Foreground="{TemplateBinding Foreground}"
                                                  TextElement.FontWeight="{TemplateBinding FontWeight}"
                                                  TextElement.FontSize="13"
                                                  Margin="2,0,0,3"/>
                                <Border Grid.Row="1"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        Background="{TemplateBinding Background}"
                                        CornerRadius="4">
                                    <ContentPresenter Margin="{TemplateBinding Padding}"/>
                                </Border>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ── Separator (implícito) ──────────────────────────────────── -->
            <!-- Igual que GroupBox: el template por defecto no respeta Background, así que el
                 separador no cambiaba de color. Este lo pinta con una brocha del tema. -->
            <Style TargetType="Separator">
                <Setter Property="Background" Value="{DynamicResource PincelSeparador}"/>
                <Setter Property="Margin"     Value="0,6"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Separator">
                            <Border Background="{TemplateBinding Background}" SnapsToDevicePixels="True"/>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ── DataGrid (implícito) ───────────────────────────────────── -->
            <Style TargetType="DataGrid">
                <Setter Property="Background"            Value="{DynamicResource PincelFondoControl}"/>
                <Setter Property="RowBackground"         Value="{DynamicResource PincelFondoControl}"/>
                <Setter Property="AlternatingRowBackground" Value="{DynamicResource PincelFondoAlt}"/>
                <Setter Property="GridLinesVisibility"   Value="Horizontal"/>
                <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource PincelSeparador}"/>
                <Setter Property="BorderBrush"           Value="{DynamicResource PincelBorde}"/>
                <Setter Property="Foreground"            Value="{DynamicResource PincelTextoPrimario}"/>
            </Style>

            <Style TargetType="DataGridColumnHeader">
                <Setter Property="Background"      Value="{DynamicResource PincelFondoCabecera}"/>
                <Setter Property="Foreground"      Value="{DynamicResource PincelTextoPrimario}"/>
                <Setter Property="BorderBrush"     Value="{DynamicResource PincelBorde}"/>
                <Setter Property="BorderThickness" Value="0,0,1,1"/>
                <Setter Property="Padding"         Value="5,4"/>
                <Setter Property="FontWeight"      Value="SemiBold"/>
            </Style>

            <Style TargetType="DataGridRow">
                <Setter Property="Background" Value="{DynamicResource PincelFondoControl}"/>
                <Setter Property="Foreground" Value="{DynamicResource PincelTextoPrimario}"/>
                <Style.Triggers>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="{DynamicResource PincelBordeFoco}"/>
                        <Setter Property="Foreground" Value="White"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- ── ListBox (implícito) ───────────────────────────────────── -->
            <Style TargetType="ListBox">
                <Setter Property="Background"  Value="{DynamicResource PincelFondoControl}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource PincelBorde}"/>
                <Setter Property="Foreground"  Value="{DynamicResource PincelTextoPrimario}"/>
            </Style>

            <!-- ── ComboBox (implícito) ──────────────────────────────────── -->
            <Style TargetType="ComboBox">
                <Setter Property="Background"  Value="{DynamicResource PincelFondoControl}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource PincelBorde}"/>
                <Setter Property="Foreground"  Value="{DynamicResource PincelTextoPrimario}"/>
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
